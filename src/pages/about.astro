---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import fs from "node:fs";
import path from "node:path";
import YAML from "yaml";

// Load experience data from YAML
const yamlPath = path.join(process.cwd(), "src/data/experience.yaml");
const yamlContent = fs.readFileSync(yamlPath, "utf-8");
const data = YAML.parse(yamlContent);
const experience = data.experience;
const certificates = data.certificates || [];
---

<Layout title="About | William Crum">
  <div class="flex flex-col min-h-screen">
	<header>
		<div class="navbar">
  <div class="navbar-start">
    <div class="dropdown bg-transparent rounded-box ">
      <label tabindex="0" class="btn btn-ghost lg:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" /></svg>
      </label>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
		<li><a href="/"> <Icon class="text-[24px]" name="mdi:home" />Home</a></li>
		<li><a href="https://meet.wcrum.dev"><Icon class="text-[24px]" name="mdi:calendar-month" />Meet</a></li>
		<li><a href="/about"><Icon class="text-[24px]" name="mdi:account-clock" />About</a></li>
		<li><a href="https://github.com/wcrum"><Icon class="text-[24px]" name="mdi:github" />Github</a></li>
		<li><a href="https://www.linkedin.com/in/wcrum/"><Icon class="text-[24px]" name="mdi:linkedin" />LinkedIn</a></li>
      </ul>
    </div>
  </div>
  <div class="navbar-center hidden lg:flex bg-transparent rounded-box">
    <ul class="menu menu-horizontal px-1 gap-2">
		<li><a href="/"><Icon class="text-[24px]" name="mdi:home" />Home</a></li>
		<li><a href="https://meet.wcrum.dev"><Icon class="text-[24px]" name="mdi:calendar-month" />Meet</a></li>
		<li><a href="/about"><Icon class="text-[24px]" name="mdi:account-clock" />About</a></li>
		<li><a href="https://github.com/wcrum"><Icon class="text-[24px]" name="mdi:github" />Github</a></li>
		<li><a href="https://www.linkedin.com/in/wcrum/"><Icon class="text-[24px]" name="mdi:linkedin" />LinkedIn</a></li>
    </ul>
  </div>
  <div class="navbar-end">
  </div>
</div>
	</header>
    <main class="flex-grow">
      <!-- About Timeline Section -->
      <section id="about" class="py-20 lg:py-32 px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl font-bold text-center mb-16">Experience</h2>
          
          <!-- Timeline Container -->
          <div class="relative timeline-container">
            <!-- Vertical Line -->
            <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-base-300"></div>
            <!-- Timeline Glow -->
            <div class="timeline-glow absolute left-8 pointer-events-none" style="top: 0; opacity: 0;"></div>
            
            {experience.map((job: any) => (
              <div class="timeline-item opacity-0 translate-y-8 transition-all duration-700 ease-out mb-16 lg:mb-24">
                <div class="flex items-center gap-6">
                  <!-- Timeline Dot -->
                  <div class="flex-shrink-0 z-10 w-16 flex justify-center">
                    <div class="w-4 h-4 rounded-full bg-base-content border-4 border-base-100 shadow-lg"></div>
                  </div>
                  
                  <!-- Content Card with Logo -->
                  <div class="flex-1 max-w-2xl">
                    <div class="glow-card relative group">
                      <div class="glow-border absolute -inset-[1px] rounded-box opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                      <div class="bg-base-200 p-6 rounded-box shadow-lg relative z-10 border border-transparent group-hover:border-base-300/50 transition-all duration-300">
                      <div class="flex gap-5">
                        <!-- Company Logo -->
                        <div class="flex-shrink-0">
                          <div class="w-16 h-16 rounded-lg bg-base-300 flex items-center justify-center border border-base-300 overflow-hidden">
                            {job.logo ? (
                              <img src={job.logo} alt={job.company} class="w-full h-full object-contain p-2" />
                            ) : (
                              <Icon class="text-[32px] text-base-content/40" name={job.icon} />
                            )}
                          </div>
                        </div>
                        
                        <!-- Content -->
                        <div class="flex-1 min-w-0">
                          <h3 class="text-xl font-bold">{job.company}</h3>
                          <p class="text-lg text-base-content/70 font-semibold">{job.title}</p>
                          <p class="text-sm text-base-content/60 mb-3">{job.timeframe}</p>
                        </div>
                      </div>
                      
                      <p class="text-base-content/80 mt-4 mb-4">{job.description}</p>
                      
                      <div class="flex flex-wrap gap-2">
                        {job.tags.map((tag: string) => (
                          <div class="badge badge-outline">{tag}</div>
                        ))}
                      </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}

          </div>
        </div>
      </section>

      <!-- Certificates Section -->
      <section id="certificates" class="pb-20 lg:pb-32 px-4">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl font-bold text-center mb-16">Certificates</h2>
          
          <div class="flex flex-wrap justify-center gap-8">
            {certificates.map((cert: any) => (
              <a 
                href={cert.url}
                target="_blank"
                rel="noopener noreferrer"
                class="cert-card group transition-transform duration-300 hover:scale-105"
                title={cert.name}
              >
                <img 
                  src={cert.image} 
                  alt={cert.name}
                  class="w-32 h-32 object-contain"
                />
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>
    <footer class="sticky bottom-0 m-5">
      <div class="flex items-center justify-between">
        <div class="bg-transparent p-5 rounded-box">
			<div class="bg-transparent p-5 rounded-box">
				<a href="mailto:will@wcrum.dev">
				  <Icon class="text-[52px]" name="mdi:mail-outline" />
				</a>
			  </div>
        </div>
        <div class="bg-transparent p-5 rounded-box">
          <a href="https://github.com/sponsors/wcrum">
            <Icon class="text-[52px]" name="line-md:coffee-loop" />
          </a>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<script is:inline>
  // Timeline scroll reveal animation
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.2
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.timeline-item').forEach(item => {
    observer.observe(item);
  });

  // Glow border effect - follows cursor (dark mode)
  document.querySelectorAll('.glow-card').forEach(card => {
    const glowBorder = card.querySelector('.glow-border');
    
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const glowColor = 'rgba(255, 255, 255, 0.6)';
      
      glowBorder.style.background = `radial-gradient(
        200px circle at ${x}px ${y}px,
        ${glowColor},
        transparent 50%
      )`;
    });
    
    card.addEventListener('mouseleave', () => {
      glowBorder.style.background = 'transparent';
    });
  });

  // Timeline vertical line glow effect - follows scroll
  const timelineContainer = document.querySelector('.timeline-container');
  const timelineGlow = document.querySelector('.timeline-glow');
  
  if (timelineContainer && timelineGlow) {
    const updateTimelineGlow = () => {
      const rect = timelineContainer.getBoundingClientRect();
      const viewportCenter = window.innerHeight / 2;
      const containerTop = rect.top;
      const containerBottom = rect.bottom;
      
      // Calculate position relative to timeline container
      const glowPosition = viewportCenter - containerTop;
      
      // Check if timeline is in view
      const isInView = containerTop < viewportCenter && containerBottom > viewportCenter;
      
      const glowColor = 'rgba(255, 255, 255, 1)';
      
      if (isInView) {
        timelineGlow.style.opacity = '1';
        timelineGlow.style.top = `${glowPosition - 100}px`;
        timelineGlow.style.background = `linear-gradient(
          to bottom,
          transparent 0%,
          ${glowColor} 30%,
          ${glowColor} 70%,
          transparent 100%
        )`;
      } else {
        timelineGlow.style.opacity = '0';
      }
    };
    
    // Update on scroll and resize
    window.addEventListener('scroll', updateTimelineGlow);
    window.addEventListener('resize', updateTimelineGlow);
    
    // Initial update
    updateTimelineGlow();
  }
</script>

<style>
  .glow-card {
    position: relative;
    border-radius: var(--rounded-box, 1rem);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .glow-card:hover {
    transform: translateY(-2px);
  }
  
  .glow-border {
    border-radius: var(--rounded-box, 1rem);
    background: transparent;
    transition: opacity 0.3s ease;
  }
  
  .glow-card:hover > div:last-child {
    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.15);
  }
  
  .timeline-glow {
    height: 200px;
    transition: opacity 0.2s ease;
    width: 3px;
    margin-left: -1px;
  }
</style>
